{
  "compilerOptions": {
    "allowJs": true,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "dotted-map": [
        "./src/lib/dotted-map"
      ],
      "dotted-map/*": [
        "./src/lib/dotted-map"
      ],
      "framer-motion": [
        "./src/lib/simple-motion"
      ],
      "framer-motion/*": [
        "./src/lib/simple-motion"
      ]
    },
    "skipLibCheck": true,
    "strictNullChecks": false
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.node.json"
    }
  ]
}